{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "vite build --mode production",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    { "source": "/presentation", "destination": "/industry-pitch.html", "permanent": true },
    { "source": "/labels", "destination": "/labels.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/((?!api/)(?!.*\\.html$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
