# BE4T Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git — it is in .gitignore.
#
# Usage:
#   cp .env.local.example .env.local
#   (then fill in your keys below)
# ─────────────────────────────────────────────────────────────────────────────

# ── App Mode ──────────────────────────────────────────────────────────────────
# "showcase" → uses JSON catalog + Spotify/YouTube APIs (Pitch env)
# "production" → uses Supabase catalog (Real Test env)
VITE_APP_MODE=showcase

# ── Thirdweb (Social Login — Google + Email) ──────────────────────────────────
# Get from: https://thirdweb.com/dashboard/settings/api-keys
# Safe to expose in frontend (scoped to allowed domains)
VITE_THIRDWEB_CLIENT_ID=

# ── Supabase (Required for production mode) ───────────────────────────────────
# Get from: https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Mailchimp (Server-side only via /api/subscribe) ───────────────────────────
# Get from: https://mailchimp.com/developer/marketing/api/root/
#
# MAILCHIMP_API_KEY     → Mailchimp Account → Profile → Extras → API keys
#                         Format: <key>-<server_prefix>  e.g.  abc123def-us21
#
# MAILCHIMP_SERVER_PREFIX → The part AFTER the dash in your API key
#                           e.g. if key ends in "-us21" → prefix = "us21"
#
# MAILCHIMP_AUDIENCE_ID → Mailchimp Dashboard → Audience → Settings → Audience name & defaults
#                         It's a string like "a1b2c3d4e5" (not the numeric list ID)
#
# After adding keys, create these Merge Fields in your Mailchimp Audience:
#   Tag name   | Field type | Required?
#   ───────────────────────────────────
#   COUNTRY    | Text       | No
#   MGENRE     | Text       | No  (Music Genre)
#   INVRANGE   | Text       | No  (Investment Range)
#   SOURCE     | Text       | No  (be4t-mvp / charged-satellite)
#
# Create them at: Audience → Settings → Audience fields and *|MERGE|* tags
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_AUDIENCE_ID=

# ── Formspree (Legacy contact form fallback) ──────────────────────────────────
# Get from: https://formspree.io/forms
VITE_FORMSPREE_URL=

# ── Resend (Legacy email — kept for backward compatibility) ──────────────────
# RESEND_API_KEY=
