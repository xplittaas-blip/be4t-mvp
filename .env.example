# BE4T — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in real values below
# 3. NEVER commit .env to version control (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-id>/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Spotify API (Client Credentials flow) ────────────────────────────────────
# Create app at: https://developer.spotify.com/dashboard
# Required for the Marketplace top-20 song catalog
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── YouTube Data API v3 (optional — for real view counts on SongCards) ────────
# Get a free key at: https://console.cloud.google.com → APIs → YouTube Data API v3
# Free tier: 10,000 units/day (one video stats call = 1 unit — effectively unlimited)
# Without this key, metricsService falls back to the calibrated streams × 0.62 ratio
VITE_YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# ── Formspree (email fallback for waitlist) ───────────────────────────────────
# Create form at: https://formspree.io — used when Supabase insert fails
VITE_FORMSPREE_URL=https://formspree.io/f/your_form_id

# ── Resend (transactional email via Supabase Edge Function) ──────────────────
# API key from: https://resend.com/api-keys
# Used by supabase/functions/welcome-email to send confirmation emails
# Add this ALSO as a Supabase Edge Function secret:
#   supabase.com → Project → Edge Functions → Secrets → RESEND_API_KEY
RESEND_API_KEY=re_your_resend_key_here

# ── Optional: Vercel Deployment ───────────────────────────────────────────────
# Set these in Vercel dashboard → Project → Settings → Environment Variables
# (Copy all VITE_* vars above — Vercel needs them at build time)
